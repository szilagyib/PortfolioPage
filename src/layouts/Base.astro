---
// Only ship the subsets we actually use — Latin + Latin Extended (for á/é/etc.).
// Cyrillic / Greek / Vietnamese subsets are excluded; saves a large chunk of CSS.
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-ext-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-ext-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-ext-600.css';
import '@fontsource/jetbrains-mono/latin-400.css';
import '@fontsource/jetbrains-mono/latin-ext-400.css';
import '@fontsource/jetbrains-mono/latin-500.css';
import '@fontsource/jetbrains-mono/latin-ext-500.css';

// `noindex` keeps error / duplicate routes (the 404) out of search
// results and out of the structured-data graph. Content pages leave it
// at the default so they index normally.
interface Props { title: string; noindex?: boolean }
const { title, noindex = false } = Astro.props;

const description =
  'Borbála Szilágyi — Software Engineering Team Lead. Cosmic interactive CV.';
// Absolute URLs so link unfurls on LinkedIn, Slack, Twitter etc.
// resolve correctly. Astro.site is set in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
// Dedicated 1200x630 card so Messenger / LinkedIn / Facebook unfurl
// at their target aspect (1.91:1) without cropping the site screenshot.
const ogImage = new URL('/previews/og-card.png', Astro.site).href;

// Schema.org Person — lets Google build a knowledge-graph entry for
// Borbála (name, role, employer, schools, verified social profiles via
// sameAs) instead of guessing from page text. Facts mirror the bio; keep
// them in sync with doors.data.ts / ai-system-prompt.ts.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Borbála Szilágyi',
  url: Astro.site?.href,
  image: new URL('/profile.jpg', Astro.site).href,
  jobTitle: 'Software Engineering Team Lead',
  email: 'szilagyiborbala8@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Budapest',
    addressCountry: 'HU',
  },
  worksFor: { '@type': 'Organization', name: 'Prolan' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Budapest University of Technology and Economics' },
    { '@type': 'CollegeOrUniversity', name: 'Eötvös Loránd University' },
  ],
  knowsLanguage: ['English', 'German', 'Hungarian'],
  knowsAbout: [
    'Software Engineering',
    'Engineering Leadership',
    'AI-assisted development',
    'Java',
    'React',
    'TypeScript',
  ],
  sameAs: [
    'https://github.com/szilagyib',
    'https://www.linkedin.com/in/szilagyiborbala8',
  ],
};

// Cloudflare Web Analytics — cookieless, GDPR-safe, first-party.
// Set PUBLIC_CF_ANALYTICS_TOKEN in the Cloudflare Pages env for the
// beacon to render; without it, no script is emitted (dev + CI safe).
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#06060f" />

    {/* Open Graph — LinkedIn, Slack, iMessage, Discord, etc. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Borbála Szilágyi" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Cosmic portfolio canvas — pentagon of destinations around a central YOU star" />
    {/* Explicit dimensions let unfurlers render the card immediately
        instead of blocking on an image fetch to measure it. */}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    {/* Twitter card — falls back to OG on platforms that don't parse it. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Cosmic portfolio canvas — pentagon of destinations around a central YOU star" />

    {/* Structured data — knowledge-graph Person entity. Skipped on
        noindex routes so error pages don't feed the graph. */}
    {!noindex && (
      <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}

    <title>{title}</title>
  </head>
  <body>
    <slot />
    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </body>
</html>
